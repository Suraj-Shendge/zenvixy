"use client";

import { useState, useRef, useCallback } from "react";
import { FileArchive, Upload, Loader2, CheckCircle2, Download, Eye, X } from "lucide-react";
import Link from "next/link";
import { compressPDF, createDownloadBlob, downloadFile, revokeUrl } from "@/lib/pdf";

export default function CompressPDF() {
  const [file, setFile] = useState<File | null>(null);
  const [preview, setPreview] = useState<string | null>(null);
  const [isProcessing, setIsProcessing] = useState(false);
  const [result, setResult] = useState<{ url: string; name: string; originalSize: number; compressedSize: number } | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [quality, setQuality] = useState<'low' | 'medium' | 'high'>('medium');
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleFileSelect = (e: React.ChangeEvent<HTMLInputElement>) => {
    const selectedFile = e.target.files?.[0];
    if (selectedFile && selectedFile.type === 'application/pdf') {
      setFile(selectedFile);
      setPreview(null);
      setResult(null);
      setError(null);
    }
  };

  const handleDrop = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    const droppedFile = e.dataTransfer.files[0];
    if (droppedFile && droppedFile.type === 'application/pdf') {
      setFile(droppedFile);
      setPreview(null);
      setResult(null);
      setError(null);
    }
  }, []);

  const handleCompress = async () => {
    if (!file) return;
    setIsProcessing(true);
    setError(null);

    try {
      const { data, name } = await compressPDF(file, quality);
      const url = createDownloadBlob(data, name);
      const originalSize = file.size;
      const compressedSize = data.length;
      setResult({ url, name, originalSize, compressedSize });
    } catch (err) {
      setError('Failed to compress PDF. Please try again.');
      console.error(err);
    } finally {
      setIsProcessing(false);
    }
  };

  const handleDownload = () => {
    if (result) {
      downloadFile(result.url, result.name);
    }
  };

  const handleReset = () => {
    if (result?.url) revokeUrl(result.url);
    setFile(null);
    setPreview(null);
    setResult(null);
    setError(null);
  };

  const formatSize = (bytes: number) => {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
  };

  const reduction = result ? Math.round((1 - result.compressedSize / result.originalSize) * 100) : 0;

  return (
    <div className="min-h-screen bg-white">
      {/* Header */}
      <div className="bg-white border-b border-gray-100">
        <div className="max-w-2xl mx-auto px-6 py-6">
          <div className="flex items-center justify-between">
            <Link href="/" className="text-sm text-gray-500 hover:text-gray-900 flex items-center gap-1">
              ← Back
            </Link>
            <h1 className="text-lg font-semibold text-gray-900">PDF Compressor</h1>
            <div className="w-16" />
          </div>
        </div>
      </div>

      {/* Content */}
      <div className="max-w-2xl mx-auto px-6 py-12">
        {!result ? (
          <div className="space-y-6">
            {/* Upload Zone */}
            <div
              onDrop={handleDrop}
              onDragOver={(e) => e.preventDefault()}
              onClick={() => fileInputRef.current?.click()}
              className={`border-2 border-dashed rounded-2xl p-12 text-center cursor-pointer transition-all ${
                file ? 'border-green-400 bg-green-50' : 'border-gray-200 hover:border-gray-300'
              }`}
            >
              <input
                ref={fileInputRef}
                type="file"
                accept=".pdf"
                onChange={handleFileSelect}
                className="hidden"
              />
              
              {file ? (
                <div className="space-y-2">
                  <CheckCircle2 className="w-12 h-12 text-green-500 mx-auto" />
                  <p className="font-medium text-gray-900">{file.name}</p>
                  <p className="text-sm text-gray-500">{formatSize(file.size)}</p>
                  <button
                    onClick={(e) => { e.stopPropagation(); handleReset(); }}
                    className="text-sm text-red-500 hover:text-red-600"
                  >
                    Remove
                  </button>
                </div>
              ) : (
                <div className="space-y-3">
                  <div className="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto">
                    <Upload className="w-8 h-8 text-gray-400" />
                  </div>
                  <div>
                    <p className="font-medium text-gray-900">Drop PDF here</p>
                    <p className="text-sm text-gray-500 mt-1">or click to browse</p>
                  </div>
                </div>
              )}
            </div>

            {/* Quality Selection */}
            {file && (
              <div className="bg-gray-50 rounded-2xl p-6">
                <p className="font-medium text-gray-900 mb-3">Compression Quality</p>
                <div className="grid grid-cols-3 gap-3">
                  {[
                    { id: 'low', label: 'High Compression', desc: 'Smaller file' },
                    { id: 'medium', label: 'Balanced', desc: 'Good quality' },
                    { id: 'high', label: 'Best Quality', desc: 'Larger file' },
                  ].map((q) => (
                    <button
                      key={q.id}
                      onClick={() => setQuality(q.id as typeof quality)}
                      className={`p-4 rounded-xl text-left transition-all ${
                        quality === q.id
                          ? 'bg-black text-white'
                          : 'bg-white border border-gray-200 hover:border-gray-300'
                      }`}
                    >
                      <p className={`font-medium ${quality === q.id ? 'text-white' : 'text-gray-900'}`}>
                        {q.label}
                      </p>
                      <p className={`text-xs mt-1 ${quality === q.id ? 'text-gray-300' : 'text-gray-500'}`}>
                        {q.desc}
                      </p>
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* Compress Button */}
            {file && (
              <button
                onClick={handleCompress}
                disabled={isProcessing}
                className="w-full py-4 bg-black text-white rounded-xl font-medium flex items-center justify-center gap-2 hover:bg-gray-800 disabled:opacity-50"
              >
                {isProcessing ? (
                  <>
                    <Loader2 className="w-5 h-5 animate-spin" />
                    Compressing...
                  </>
                ) : (
                  <>
                    <FileArchive className="w-5 h-5" />
                    Compress PDF
                  </>
                )}
              </button>
            )}

            {error && (
              <p className="text-red-500 text-sm text-center">{error}</p>
            )}
          </div>
        ) : (
          /* Result */
          <div className="bg-gray-50 rounded-2xl p-8 text-center">
            <CheckCircle2 className="w-16 h-16 text-green-500 mx-auto mb-4" />
            <h2 className="text-xl font-semibold text-gray-900 mb-2">Compression Complete!</h2>
            
            <div className="grid grid-cols-3 gap-4 my-6">
              <div className="bg-white rounded-xl p-4">
                <p className="text-xs text-gray-500 mb-1">Original</p>
                <p className="font-semibold text-gray-900">{formatSize(result.originalSize)}</p>
              </div>
              <div className="bg-white rounded-xl p-4">
                <p className="text-xs text-gray-500 mb-1">Compressed</p>
                <p className="font-semibold text-green-600">{formatSize(result.compressedSize)}</p>
              </div>
              <div className="bg-white rounded-xl p-4">
                <p className="text-xs text-gray-500 mb-1">Reduced</p>
                <p className="font-semibold text-red-600">{reduction}%</p>
              </div>
            </div>

            <div className="flex gap-3">
              <button
                onClick={handleDownload}
                className="flex-1 py-3 bg-black text-white rounded-xl font-medium flex items-center justify-center gap-2 hover:bg-gray-800"
              >
                <Download className="w-4 h-4" />
                Download
              </button>
              <button
                onClick={handleReset}
                className="px-6 py-3 bg-white border border-gray-200 rounded-xl font-medium hover:bg-gray-50"
              >
                Compress Another
              </button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
